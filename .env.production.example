# Production environment template.
# Copy to .env.production on the server, fill in real values, chmod 600.
# .env.production must never be committed.

# --- Django core ---
DEBUG=off
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
ALLOWED_HOSTS=your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com
ENVIRONMENT=production

# --- Database (RDS PostgreSQL) ---
DATABASE_URL=postgres://mediaflow:PASSWORD@your-rds-endpoint.eu-north-1.rds.amazonaws.com:5432/mediaflow

# --- Redis / Celery (redis service from docker-compose.prod.yml) ---
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Frontend ---
FRONTEND_URL=https://your-domain.com
SITE_URL=https://your-domain.com
EVENT_INVITE_JOIN_PATH=/join

# --- AWS S3 (IAM user scoped to the production bucket) ---
YOUR_ACCESS_KEY_S3=
YOUR_SECRET_KEY_S3=
AWS_STORAGE_BUCKET_NAME_S3=
AWS_S3_REGION_NAME=eu-north-1

# --- Google OAuth (add the production domain to redirect URIs) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Encryption ---
# Generate: python manage.py generate_encryption_key
ENCRYPTION_KEY=

# --- Email (optional) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=
